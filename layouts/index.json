[
{{- $pages := where .Site.RegularPages "Section" "in" .Site.Params.mainSections -}}
{{- range $index, $page := $pages.ByDate.Reverse -}}
  {{- if gt $index 0 }},{{ end }}
  {
    "title": {{ $page.Title | jsonify }},
    "url": {{ $page.RelPermalink | jsonify }},
    "content": {{ (printf "%s %s %s" $page.Title ($page.Params.description | default "") ($page.Plain | default $page.RawContent) | replaceRE "\\s+" " " | strings.TrimSpace) | jsonify }}
  }
{{- end }}
]
